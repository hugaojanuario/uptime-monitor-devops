# Port the backend will listen on
PORT=8080

# Database credentials
DB_HOST=localhost
DB_PORT=5432
DB_NAME=uptime
DB_USER=admin
DB_PASSWORD=123456
DB_SSLMODE=disable

# File where the check results are appended
RESULTS_FILE=results.txt

# Timeout of each HTTP check
CHECK_TIMEOUT=10s

# Timezone used in the API responses and in the results file
TZ=America/Sao_Paulo
